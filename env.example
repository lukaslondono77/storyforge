# Copy this to .env and fill in your values

# Long random string — run: openssl rand -hex 32
JWT_SECRET=replace_with_long_random_string

# GitHub Personal Access Token (your bot token — writers never see this)
# Create at: https://github.com/settings/tokens → scope: public_repo
GITHUB_BOT_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# The GitHub repo where stories are stored as .md files
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=storyforge-content
