# ── Copy this to .env and fill in your values ──────────────────

# A secret string — make it long and random (e.g. run: openssl rand -hex 32)
JWT_SECRET=replace_with_a_long_random_string

# GitHub Personal Access Token (your bot token)
# Create at: https://github.com/settings/tokens
# Needs scope: repo (for private) or public_repo (for public)
GITHUB_BOT_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# The GitHub account and repo where stories will be stored
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=storyforge-content
